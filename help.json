        "Crunch: Pre-tape grit",
        "Volume: Output level",
        "—",
        "Samples Folder: Library",
        " jump (LL/SB/90/…)",
        "Reverse: Play tape back",
        "Half Speed: ‑1 octave",
        "Sample Start: Skip in",
        "Crossfade %: Loop xfade",
        " width 5–130 ms",
        "Loop / Map / Auto Retune",
        "Seq Base: -N.wav offset"
      ]
    },
    {
      "title": "FX 1",
      "lines": [
        "Auto-Wah: Envelope BPF",
        "Vibrato: 3-voice chorus",
        "Tremolo: 0.5→22 Hz",
        " (snap past 80%)",
        "Rotary: Physical Leslie",
        " 0–25% real, 25–100%",
        " above-realistic spin",
        "DJ Filter: LP/HP sweep",
        "Texturizer: Grain cloud",
        " freeze past 96%",
        "Delay: BBD-style echo",
        "Reverb: Diffuse plate",
        "—",
        "FX Chain (menu, 10):",
