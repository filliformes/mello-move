    {
      "title": "Banks & Libraries",
      "lines": [
        "instruments/<lib>/<bnk>",
        "Free WAV libraries:",
        " LL = Leisureland",
        " SB = Sonic Bloom",
        " 90 = 90s Archive CD",
        "Add your own folder →",
        " appears as new lib",
        "—",
        "File names accepted:",
        " A2.wav, C#3.wav",
        " Bb4.wav (C4 = 60)",
        " 60.wav (bare MIDI)",
        " prefix-8.wav (seq)",
        "16-bit PCM mono/stereo"
      ]
    },
    {
      "title": "MIDI",
      "lines": [
        "Note on/off ✓",
        "Mod wheel (CC1) →",
        " vibrato amount",
        "Aftertouch →",
        " tape flutter depth",
        "Pitch bend ±2 st",
        "CC120/123: Panic",
        " (all notes off)",
        "—",
        "Same-note retrigger",
        " auto-releases prev",
        " voice (no stuck",
        " notes from USB MIDI)"
      ]
    },
    {
      "title": "Tips",
      "lines": [
        "Two banks layer dual",
        " Mellotrons — turn",
        " A · B for crossfade",
        "Auto Retune is OFF by",
        " default — leave it",
        " off for natural tape",
        " wobble, on for tuning",
        "Crossfade % up to 130",
        " ms for sustained pads",
        "Rotary spool-up = 60ms",
        " spool-down = 30 ms",
        "Wow + Flutter add a",
        " lot at very low knob",
        " values — try 5–15%",
        "Tape Style Off skips",
        " sat & head bump but",
        " keeps wow/flutter"
      ]
    }
  ]
}
